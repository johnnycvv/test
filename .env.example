# CloudCall Environment Configuration
# Copy this to .env and fill in your values

# Database
DB_PASS=cloudcall_dev_pass

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-64-random-chars
JWT_REFRESH_SECRET=change-me-refresh-secret

# App URLs
API_URL=http://localhost:3001
WS_URL=ws://localhost:3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# AWS S3 for recordings (optional for dev - recordings saved locally)
S3_BUCKET=cloudcall-recordings
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# WebRTC STUN/TURN
STUN_SERVER=stun:stun.l.google.com:19302

# ── Stripe payments ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Get these from https://dashboard.stripe.com/apikeys
# Webhook endpoint to register: POST /api/payments/webhook

# ── App URL (used in Stripe redirect URLs) ───────────────────────────────────
APP_URL=https://your-domain.com

# ── Telegram support bot ─────────────────────────────────────────────────────
# Replace 'your_support_bot' in TelegramWidget.js with your actual bot username

# ── Twilio WebRTC ─────────────────────────────────────────────────────────────
# Get all of these from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CALLER_ID=+441234567890
TWILIO_DEFAULT_QUEUE=default
